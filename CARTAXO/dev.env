# =========================
# api-financiamentos-simul
# Ambiente: DEV
# =========================

# -------------------------
# Perfil / execução
# -------------------------
ACTIVE_PROFILE=dev
SERVER_PORT=7774
MAX_THREADS=8
MAX_REQUESTS_EXTERNOS=0
JAVA_OPTS=-Xms64m -Xmx512m -Duser.timezone=America/Sao_Paulo -Duser.language=pt -Duser.country=BR
JAVA_DEBUG=
SPRING_OPTS=

# -------------------------
# Redis
# -------------------------
REDIS_HOSTNAME=redis.new-front-dev.svc.cluster.local
REDIS_PORT=6379
# Observação: no Dockerfile atual essa variável não é injetada via argumento,
# mas o Spring Boot lê automaticamente SPRING_REDIS_PASSWORD.
SPRING_REDIS_PASSWORD=changeme
# Legado (mantida por compatibilidade com versões antigas de imagem/scripts):
NEWFRONT_REDIS_PASSWORD=changeme

# -------------------------
# MongoDB
# -------------------------
MONGODB_URI=mongodb://<user>:<password>@<host>:27017/propostas?authSource=admin
MONGODB_PARCEIROS_URI=mongodb://<user>:<password>@<host>:27017/simulacoes_parceiros?authSource=admin

# -------------------------
# APIs internas
# -------------------------
API_CLIENTES=https://sandboxapidev.bancotoyota.com.br/clientes/v3
API_EMPLACAMENTOS=http://api-emplacamento-new-front-dev.apps.aro.dev.corp.btb/emplacamentos
API_ORIGENS_NEGOCIOS=http://api-origens-negocios-new-front-dev.apps.aro.dev.corp.btb/origens-negocios
API_CESTAS_SERVICOS=http://api-cestaservicos-new-front-dev.apps.aro.dev.corp.btb/cestas-servicos
API_PLANOS=http://api-planos-v2-new-front-dev.apps.aro.dev.corp.btb/financiamentos/planos
API_MOTOR_TAXAS_URL=http://api-motor-taxas-planos-new-front-dev.apps.aro.dev.corp.btb/motor/taxas
API_VEICULOS=http://api-veiculos-new-front-dev.apps.aro.dev.corp.btb/veiculos
API_FINANCIAMENTOS_PROPOSTAS=http://api-financiamentos-propo-new-front-dev.apps.aro.dev.corp.btb/financiamentos/propostas

# -------------------------
# APIs externas
# -------------------------
API_SEGURO_MECANICA_URL=https://sandboxapidev.bancotoyota.com.br/seguros/v2/garantia/elegibilidades/
API_PRESTAMISTA_PLUS_URL=https://sandboxapidev.bancotoyota.com.br/seguros/protecao/financeira/v1/taxas

# -------------------------
# OAuth - Parceiros
# -------------------------
SERVICE_URL=https://sandboxapidev.bancotoyota.com.br/
TOKEN_URL=https://sandboxapidev.bancotoyota.com.br/oauth
USERNAME_PARCEIROS=<preencher>
PASSWORD_PARCEIROS=<preencher>
CLIENT_ID_PARCEIROS=<preencher>
CLIENT_SECRET_PARCEIROS=<preencher>

# -------------------------
# OAuth - Direct
# -------------------------
DIRECT_USERNAME=<preencher>
DIRECT_PASSWORD=<preencher>
DIRECT_CLIENT_ID=<preencher>
DIRECT_CLIENT_SECRET=<preencher>

# -------------------------
# Feature flags
# -------------------------
HABILITAR_VEICULOS=true
HABILITAR_SIMULACAO_PARCEIROS=true
HABILITAR_FILTRO_ID_MODALIDADE=true
HABILITAR_CONSULTA_SEGURO_PRESTAMISTA=true
MOTOR_TAXAS_ENABLED=true

# -------------------------
# Retry / logs
# -------------------------
LIMITE_RETENTATIVAS=20
DELAY_ENTRE_RETENTATIVAS=1000
NIVEL_LOG_GERAL=INFO
NIVEL_LOG_ESPECIFICO=WARN
